{{script}}
# DMP CSV Template for Data Management Plans
# This template renders DMP records in CSV format with essential fields
# Required fields: Name, ID, Type, Owner, Status Fields, Data Fields
{{endscript}}
"Name","ID","Type","Owner","Status_State","Status_Action","Status_CreatedDate","Status_ModifiedDate","Status_Message","Title","ProjectDescription","StartDate","DmpSearchable","Grant_Source","Grant_ID","Keywords","DataSize","SizeUnit","SoftwareDevelopment","TechnicalResources","DataDescription","DataCategories","PreservationDescription"
{{for record in records}}
"{{record.get('name', 'Not Provided').replace('"', '""')}}","{{record.get('id', 'Not Provided')}}","DMP","{{record.get('owner', 'Not Provided')}}","{{record.get('status', {}).get('state', 'Not Provided')}}","{{record.get('status', {}).get('action', 'Not Provided')}}","{{record.get('status', {}).get('createdDate', 'Not Provided')}}","{{record.get('status', {}).get('modifiedDate', 'Not Provided')}}","{{record.get('status', {}).get('message', 'Not Provided').replace('"', '""')}}","{{record.get('data', {}).get('title', 'Not Provided').replace('"', '""')}}","{{record.get('data', {}).get('projectDescription', 'Not Provided').replace('"', '""')}}","{{record.get('data', {}).get('startDate', 'Not Provided')}}","{{record.get('data', {}).get('dmpSearchable', 'Not Provided')}}","{{record.get('data', {}).get('funding', {}).get('grant_source', 'Not Provided')}}","{{record.get('data', {}).get('funding', {}).get('grant_id', 'Not Provided')}}","{{'; '.join(record.get('data', {}).get('keywords', []))}}","{{record.get('data', {}).get('dataSize', 'Not Provided') if record.get('data', {}).get('dataSize') is not None else 'Not Provided'}}","{{record.get('data', {}).get('sizeUnit', 'Not Provided')}}","{{record.get('data', {}).get('softwareDevelopment', {}).get('development', 'Not Provided')}}","{{'; '.join(record.get('data', {}).get('technicalResources', []))}}","{{record.get('data', {}).get('dataDescription', 'Not Provided').replace('"', '""')}}","{{'; '.join(record.get('data', {}).get('dataCategories', []))}}","{{record.get('data', {}).get('preservationDescription', 'Not Provided').replace('"', '""')}}"
{{endfor}}
