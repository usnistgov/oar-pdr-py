## Data Assets

**Asset Details:**

{{script}}
assets = record.get('dataAssets', [])
if assets:
    lines = []
    lines.append("| Asset Name | Description | Size | Format | Location |")
    lines.append("| --- | --- | --- | --- | --- |")
    
    for asset in assets:
        row = "| {name} | {desc} | {size} | {format} | {location} |".format(
            name=md_escape(asset.get('name', 'Not Provided')),
            desc=md_escape(asset.get('description', 'Not Provided')),
            size=md_escape(asset.get('estimatedSize', 'Not Provided')),
            format=md_escape(asset.get('format', 'Not Provided')),
            location=md_escape(asset.get('storageLocation', 'Not Provided'))
        )
        lines.append(row)
    
    assets_table = "\n".join(lines)
else:
    assets_table = "*No data assets specified.*"
{{endscript}}

