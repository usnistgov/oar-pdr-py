## Data Sources

**Primary Data Sources:**

{{script}}
data_sources = record.get('dataSources', [])
if data_sources:
    lines = []
    lines.append("| Source Name | Description | Type | Format | Access |")
    lines.append("| --- | --- | --- | --- | --- |")
    
    for ds in data_sources:
        row = "| {name} | {desc} | {type} | {format} | {access} |".format(
            name=md_escape(ds.get('name', 'Not Provided')),
            desc=md_escape(ds.get('description', 'Not Provided')),
            type=md_escape(ds.get('sourceType', 'Not Provided')),
            format=md_escape(ds.get('dataFormat', 'Not Provided')),
            access=md_escape(ds.get('accessMethod', 'Not Provided'))
        )
        lines.append(row)
    
    data_sources_table = "\n".join(lines)
else:
    data_sources_table = "*No data sources specified.*"
{{endscript}}

{{data_sources_table}}

